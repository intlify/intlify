*.bmp     binary
*.tiff    binary
*.zip     binary
*.jar     binary
*.gz      binary
*.tgz     binary
*.bz2     binary
*.xz      binary
*.7z      binary
*.pdf     binary
*.woff    binary
*.woff2   binary
*.ttf     binary
*.otf     binary
*.eot     binary
*.wasm    binary
*.so      binary
*.dll     binary
*.exe     binary
*.class   binary
