    "prepare": "vp config"
  },
  "devDependencies": {
    "@kazupon/vp-config": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0"
}
