{
  "name": "intlify-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check-rust-headers": "node scripts/check-rust-headers.js",
    "bench:mf-parser": "vp run mf-parser-bench#bench",
    "bench:mf-parser:smoke": "vp run mf-parser-bench#bench:smoke",
    "ready": "vp check && vp run -r test && vp run -r build",
    "dev": "vp run website#dev",
