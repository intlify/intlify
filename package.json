{
  "name": "intlify-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:rust": "vp run check:rust:headers && vp run check:rust:fmt && vp run check:rust:clippy && vp run check:rust:compile",
    "check:rust:headers": "node scripts/check-rust-headers.js",
    "check:rust:fmt": "cargo fmt --all -- --check",
    "check:rust:clippy": "cargo clippy --all-targets",
    "check:rust:compile": "cargo check --all-targets",
    "bench:mf-parser": "vp run mf-parser-bench#bench",
    "bench:mf-parser:smoke": "vp run mf-parser-bench#bench:smoke",
    "fmt": "cargo fmt --all && vp fmt",
    "ready": "vpr check && vp run -r test && vp run -r build",
    "dev": "vp run website#dev",
    "check": "vp run check:rust && vp check",
    "test": "cargo test --all-targets && vp test",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@kazupon/vp-config": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.7.0"
}
