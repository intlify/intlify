          TOKEN RightBraceToken @ 15..16 "}"
    ComplexBody @ 17..28
      QuotedPattern @ 17..28
        TOKEN LeftDoubleBraceToken @ 17..19 "{{"
        Pattern @ 19..26
          Text @ 19..22
            TOKEN TextToken @ 19..22 "Hi "
          Placeholder @ 22..26
            VariableExpression @ 22..26
