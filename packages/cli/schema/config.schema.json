{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "CatalogConfig": {
      "additionalProperties": false,
      "description": "One validated resource catalog definition.",
      "properties": {
        "exclude": {
          "description": "Project-relative patterns removed from this definition's include set.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "format": {
          "description": "Optional shipped host-format override.",
          "enum": ["json"],
          "type": "string"
        },
        "include": {
          "description": "Non-empty project-relative resource membership patterns.",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": ["include"],
      "type": "object"
    },
    "EmptyConfig": {
      "additionalProperties": false,
      "type": "object"
    },
    "FormatterConfig": {
      "additionalProperties": false,
      "properties": {
        "ignorePatterns": {
          "default": [],
          "description": "Project-root-relative formatter ignore patterns.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "mode": {
          "allOf": [
            {
              "$ref": "#/definitions/FormatterMode"
            }
          ],
          "default": "standard",
          "description": "Formatting strategy. Defaults to standard."
        }
      },
      "type": "object"
    },
    "FormatterMode": {
      "enum": ["standard", "preserve"],
      "type": "string"
    },
    "ResourcesConfig": {
      "additionalProperties": false,
      "description": "Validated project resource configuration.",
      "properties": {
        "catalogs": {
          "description": "Project-relative resource catalog definitions. Omission preserves absent policy; an empty array disables catalogs.",
          "items": {
            "$ref": "#/definitions/CatalogConfig"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  },
  "properties": {
    "$schema": {
      "description": "Editor-facing schema metadata. Ignored by the CLI at runtime.",
      "type": "string"
    },
    "fmt": {
      "$ref": "#/definitions/FormatterConfig",
      "description": "Formatter configuration."
    },
    "lint": {
      "$ref": "#/definitions/EmptyConfig",
      "description": "Linter configuration. Phase 3C accepts only an empty object."
    },
    "resources": {
      "$ref": "#/definitions/ResourcesConfig",
      "description": "Resource catalog configuration."
    }
  },
  "title": "ProjectConfigFile",
  "type": "object"
}
